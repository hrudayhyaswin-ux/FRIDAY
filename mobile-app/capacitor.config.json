{
  "appId": "com.friday.ai.assistant",
  "appName": "FRIDAY AI",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#000408"
  },
  "ios": {
    "backgroundColor": "#000408",
    "contentInset": "always"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#000408",
      "showSpinner": false
    }
  }
}
